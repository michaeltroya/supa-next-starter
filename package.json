    "@tanstack/react-query-devtools": "^5.100.9",
    "@vercel/analytics": "^1.6.1",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
